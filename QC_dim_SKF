<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>치수관리 위험 모니터링</title>
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@400;500;600;700;900&display=swap">
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
<style>
:root{--bg:#0f172a;--surface:#1e293b;--surface2:#334155;--border:#475569;--accent:#f59e0b;--accent2:#d97706;--ok:#22c55e;--ok-bg:rgba(34,197,94,.1);--ng:#ef4444;--ng-bg:rgba(239,68,68,.1);--warn:#f59e0b;--warn-bg:rgba(245,158,11,.1);--text:#e2e8f0;--text2:#94a3b8;--text3:#64748b;--radius:12px}
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
body{font-family:'Noto Sans KR',sans-serif;background:var(--bg);color:var(--text);min-height:100vh;padding-bottom:40px}
.hdr{background:linear-gradient(135deg,#92400e,#d97706);padding:20px 16px 16px;text-align:center;position:relative;overflow:hidden}
.hdr::before{content:'';position:absolute;top:-50%;left:-50%;width:200%;height:200%;background:repeating-linear-gradient(45deg,transparent,transparent 10px,rgba(255,255,255,.02) 10px,rgba(255,255,255,.02) 20px);pointer-events:none}
.hdr h1{font-size:18px;font-weight:900;position:relative}.hdr p{font-size:11px;color:#fcd34d;margin-top:3px;position:relative}
.form-wrap{max-width:600px;margin:0 auto;padding:12px}
.card{background:var(--surface);border:1px solid rgba(255,255,255,.06);border-radius:var(--radius);padding:16px;margin-bottom:12px}
.card-title{font-size:12px;font-weight:700;color:var(--accent);letter-spacing:.5px;margin-bottom:12px;display:flex;align-items:center;gap:6px}
.card-title::before{content:'';width:3px;height:14px;background:var(--accent);border-radius:2px;flex-shrink:0}
.fg{margin-bottom:10px}
.fg label{display:block;font-size:11px;font-weight:600;color:var(--text2);margin-bottom:4px}
.fg select,.fg input{width:100%;padding:10px 11px;font-size:14px;font-family:inherit;background:var(--bg);border:1.5px solid var(--border);border-radius:8px;color:var(--text);appearance:auto}
.fg select:focus,.fg input:focus{outline:none;border-color:var(--accent)}
.fg-row{display:grid;grid-template-columns:1fr 1fr;gap:8px}
.tabs{display:flex;background:var(--surface);border-bottom:2px solid rgba(255,255,255,.06)}
.tab{flex:1;padding:11px 4px;text-align:center;font-size:13px;font-weight:600;cursor:pointer;border-bottom:3px solid transparent;color:var(--text3);transition:all .15s}
.tab.on{color:var(--accent);border-bottom-color:var(--accent)}
.pnl{display:none}.pnl.on{display:block}
.btn-sm{padding:8px 14px;border:none;border-radius:8px;font-size:12px;font-weight:700;cursor:pointer;font-family:inherit;transition:transform .1s}
.btn-sm:active{transform:scale(.96)}
.submit-btn{width:100%;padding:14px;font-size:15px;font-weight:800;background:linear-gradient(135deg,#92400e,#f59e0b);border:none;border-radius:var(--radius);color:#fff;cursor:pointer;font-family:inherit;box-shadow:0 4px 16px rgba(245,158,11,.25)}
.submit-btn:active{transform:scale(.97)}
.submit-btn:disabled{opacity:.5;cursor:not-allowed}

/* 경고 카드 */
.warn-card{background:var(--surface);border:1.5px solid var(--border);border-radius:var(--radius);padding:14px;margin-bottom:10px;transition:border-color .2s}
.warn-card.danger{border-color:var(--ng);background:linear-gradient(135deg,var(--surface),rgba(239,68,68,.05))}
.warn-card.warning{border-color:var(--warn);background:linear-gradient(135deg,var(--surface),rgba(245,158,11,.05))}
.warn-card.ok{border-color:var(--ok);background:linear-gradient(135deg,var(--surface),rgba(34,197,94,.05))}
.wc-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:8px}
.wc-part{font-size:15px;font-weight:800;color:var(--text)}
.wc-badge{font-size:10px;font-weight:700;padding:3px 8px;border-radius:6px}
.wc-badge.danger{background:var(--ng-bg);color:var(--ng)}
.wc-badge.warning{background:var(--warn-bg);color:var(--warn)}
.wc-rows{display:grid;grid-template-columns:1fr 1fr;gap:4px;font-size:11px;color:var(--text2)}
.wc-rows .wc-label{color:var(--text3)}
.wc-rows .wc-val{font-weight:600;color:var(--text);text-align:right}
.wc-bar{margin-top:8px;background:var(--bg);border-radius:4px;height:20px;position:relative;overflow:hidden;border:1px solid var(--border)}
.wc-bar-fill{height:100%;border-radius:3px;transition:width .5s}
.wc-bar-marker{position:absolute;top:0;height:100%;width:2px;background:var(--text)}
.wc-bar-label{position:absolute;top:50%;transform:translateY(-50%);font-size:9px;font-weight:700;color:var(--text)}

/* 통계 바 */
.stats-row{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-bottom:12px}
.stat-box{text-align:center;padding:12px 8px;background:var(--bg);border:1px solid rgba(255,255,255,.06);border-radius:10px}
.stat-num{font-size:22px;font-weight:900}
.stat-label{font-size:10px;color:var(--text3);margin-top:2px}

/* 로딩 */
.loading{text-align:center;padding:30px;color:var(--text2);font-size:13px}
.spin{display:inline-block;width:20px;height:20px;border:2.5px solid var(--border);border-top-color:var(--accent);border-radius:50%;animation:spin .8s linear infinite;margin-right:8px;vertical-align:middle}
@keyframes spin{to{transform:rotate(360deg)}}

/* 차트 영역 */
.chart-area{margin-top:8px;padding:8px;background:var(--bg);border-radius:8px;border:1px solid rgba(255,255,255,.06);overflow:hidden}
.chart-area img{width:100%;border-radius:4px}

.toast{position:fixed;bottom:70px;left:50%;transform:translateX(-50%);background:rgba(0,0,0,.85);color:#fff;padding:8px 18px;border-radius:18px;font-size:12px;font-weight:600;z-index:9999;opacity:0;transition:opacity .3s;pointer-events:none}.toast.show{opacity:1}

/* 필터 */
.filter-row{display:flex;gap:6px;margin-bottom:10px;flex-wrap:wrap}
.filter-chip{padding:6px 12px;border-radius:20px;font-size:11px;font-weight:600;cursor:pointer;border:1.5px solid var(--border);background:var(--bg);color:var(--text2);transition:all .15s}
.filter-chip.on{background:var(--accent);color:#000;border-color:var(--accent)}
.filter-chip:active{transform:scale(.95)}
</style>
</head>
<body>
<div class="hdr">
<h1>📐 치수관리 위험 모니터링 (SKF씰)</h1>
<p>구글시트 연동 · 공차한계 80% 임박 분석 · QuickChart 그래프</p>
</div>
<div class="tabs">
<div class="tab on" onclick="swTab(0)">🚨 위험 분석</div>
<div class="tab" onclick="swTab(1)">📋 전체 데이터</div>
<div class="tab" onclick="swTab(2)">⚙ 설정</div>
</div>

<!-- ===== 0: 위험 분석 ===== -->
<div class="pnl on" id="pnl0">
<div class="form-wrap">
  <div class="card">
    <div class="card-title" style="justify-content:space-between">
      <span>🚨 공차한계 80% 임박 분석</span>
      <button class="btn-sm" onclick="runAnalysis()" style="background:var(--accent);color:#000" id="btnAnalysis">🔄 분석 실행</button>
    </div>
    <div style="font-size:10px;color:var(--text3);margin-bottom:10px;padding:6px 8px;background:rgba(245,158,11,.08);border-radius:6px;line-height:1.6">
      💡 구글시트에서 최근 1년 데이터를 가져와 분석합니다<br>
      • 중심공차형: 상/하한 80% 위험구간 진입 여부<br>
      • 제로근접형(진원도,평면도 등): 상한 80% 초과 여부<br>
      • 분석 대상: 최근 14일 이내 측정된 품번
    </div>
    <div id="analysisStatus" style="display:none;font-size:11px;color:var(--accent);padding:6px 0"></div>
  </div>

  <!-- 통계 -->
  <div id="statsArea" style="display:none">
    <div class="stats-row">
      <div class="stat-box"><div class="stat-num" style="color:var(--ng)" id="statDanger">0</div><div class="stat-label">위험 항목</div></div>
      <div class="stat-box"><div class="stat-num" style="color:var(--text)" id="statTotal">0</div><div class="stat-label">분석 조합</div></div>
      <div class="stat-box"><div class="stat-num" style="color:var(--text2)" id="statData">0</div><div class="stat-label">총 데이터</div></div>
    </div>
  </div>

  <!-- 필터 -->
  <div id="filterArea" style="display:none">
    <div class="filter-row" id="filterChips"></div>
  </div>

  <!-- 경고 목록 -->
  <div id="warningList"></div>

  <!-- 엑셀 다운로드 -->
  <div id="exportArea" style="display:none;margin-top:8px">
    <button class="btn-sm" onclick="exportWarnings()" style="width:100%;background:var(--surface2);color:var(--text2);border:1px solid var(--border);padding:10px">📥 경고 목록 엑셀 다운로드</button>
  </div>
</div>
</div>

<!-- ===== 1: 전체 데이터 ===== -->
<div class="pnl" id="pnl1">
<div class="form-wrap">
  <div class="card">
    <div class="card-title" style="justify-content:space-between">
      <span>📋 전체 데이터 조회</span>
      <button class="btn-sm" onclick="loadAllData()" style="background:var(--accent2);color:#fff">🔄</button>
    </div>
    <div class="fg-row" style="margin-bottom:8px">
      <div class="fg"><label>부품번호 검색</label><input type="text" id="searchPart" placeholder="부품번호" oninput="renderAllData()"></div>
      <div class="fg"><label>항목 검색</label><input type="text" id="searchItem" placeholder="항목명" oninput="renderAllData()"></div>
    </div>
    <div id="allDataStatus" style="font-size:11px;color:var(--text3);margin-bottom:8px"></div>
    <div id="allDataList"></div>
  </div>
</div>
</div>

<!-- ===== 2: 설정 ===== -->
<div class="pnl" id="pnl2">
<div class="form-wrap">
  <div class="card">
    <div class="card-title">GAS 웹앱 설정</div>
    <div style="font-size:10px;color:var(--text3);margin-bottom:10px;padding:6px 8px;background:rgba(245,158,11,.08);border-radius:6px;line-height:1.6">
      💡 구글시트의 Apps Script에 데이터 조회 API를 추가하고 웹앱으로 배포하세요.<br>
      배포된 URL을 아래에 입력하면 데이터를 가져올 수 있습니다.
    </div>
    <div class="fg"><label>GAS 웹앱 URL</label><input type="text" id="stgGasUrl" placeholder="https://script.google.com/macros/s/.../exec"></div>
    <button class="submit-btn" onclick="testGasConn()" style="margin-bottom:8px;font-size:13px;padding:10px">🔗 연결 테스트</button>
    <div id="stgConnStatus" style="font-size:11px;color:var(--text3);margin-top:4px"></div>
  </div>
  <div class="card">
    <div class="card-title">분석 기준 설정</div>
    <div class="fg-row">
      <div class="fg"><label>위험 기준 (%)</label><input type="number" id="stgThreshold" value="80" min="50" max="99" step="1"></div>
      <div class="fg"><label>최근 N일 필터</label><input type="number" id="stgDays" value="14" min="1" max="90" step="1"></div>
    </div>
  </div>
  <button class="submit-btn" onclick="saveSettings()">💾 설정 저장</button>
  <div id="stgSaveStatus" style="text-align:center;font-size:11px;margin-top:8px;color:var(--text3)"></div>

  <div class="card" style="margin-top:12px">
    <div class="card-title">GAS doGet 코드 (구글시트에 추가)</div>
    <div style="font-size:10px;color:var(--text3);margin-bottom:8px;line-height:1.6">
      기존 GAS의 <code>doGet</code> 함수를 아래로 교체하세요.<br>
      교체 후 <b>새 배포</b>로 재배포해야 합니다.
    </div>
    <pre id="gasCode" style="background:var(--bg);border:1px solid var(--border);border-radius:8px;padding:10px;font-size:10px;color:#a5f3fc;overflow-x:auto;white-space:pre-wrap;word-break:break-all;max-height:300px;overflow-y:auto;line-height:1.5;cursor:pointer" onclick="copyGasCode()"></pre>
    <button class="btn-sm" onclick="copyGasCode()" style="margin-top:6px;width:100%;background:var(--surface2);color:var(--text2);border:1px solid var(--border)">📋 코드 복사</button>
  </div>
</div>
</div>

<div class="toast" id="toast"></div>

<script>
const LS_KEY='DIM_CHECK_STG';
const ZERO_APPROACH_ITEMS=['진원도','평면도','동심도','원통도','직각도','내경 Burr','외경 Burr','흔들림'];

// GAS doGet 교체 코드
const GAS_CODE=`// 기존 doGet을 이 코드로 교체하세요
function doGet(e) {
  var action = (e && e.parameter && e.parameter.action) || '';

  if (action === 'getData') {
    var ss = SpreadsheetApp.openById(SHEET_ID);
    var sheet = ss.getSheetByName(SHEET_NAME);
    var lastRow = sheet.getLastRow();
    var lastCol = sheet.getLastColumn();
    if (lastRow < 2) return jsonResponse({success:true, data:[], count:0});
    var cols = Math.min(lastCol, 36);
    var headers = sheet.getRange(1,1,1,cols).getValues()[0];
    var data = sheet.getRange(2,1,lastRow-1,cols).getValues();
    var rows = [];
    for (var i=0; i<data.length; i++) {
      var obj = {};
      for (var j=0; j<cols; j++) {
        obj['c'+j] = data[i][j];
      }
      rows.push(obj);
    }
    return ContentService.createTextOutput(JSON.stringify({
      success: true,
      headers: headers,
      data: rows,
      count: rows.length
    })).setMimeType(ContentService.MimeType.JSON);
  }

  if (action === 'findFile') {
    var partNo = (e.parameter.partNo || '').trim();
    if (!partNo) return ContentService.createTextOutput(JSON.stringify({success:false,message:'partNo 필요'})).setMimeType(ContentService.MimeType.JSON);
    try {
      var folder = DriveApp.getFolderById(DRAWING_FOLDER_ID);
      var files = folder.searchFiles("title contains '" + partNo + "' and trashed = false");
      var result = [];
      while (files.hasNext()) {
        var f = files.next();
        result.push({name: f.getName(), url: f.getUrl(), size: f.getSize(), id: f.getId()});
      }
      return ContentService.createTextOutput(JSON.stringify({success:true, files:result, count:result.length})).setMimeType(ContentService.MimeType.JSON);
    } catch(err) {
      return ContentService.createTextOutput(JSON.stringify({success:false, message:err.toString()})).setMimeType(ContentService.MimeType.JSON);
    }
  }

  return ContentService.createTextOutput(
    "측정DB 웹앱 정상 작동 중"
  ).setMimeType(ContentService.MimeType.TEXT);
}`;

function getStg(){return JSON.parse(localStorage.getItem(LS_KEY)||'{}')}
function toast(m){const el=document.getElementById('toast');el.textContent=m;el.classList.add('show');clearTimeout(window._tt);window._tt=setTimeout(()=>el.classList.remove('show'),2000)}
function swTab(n){document.querySelectorAll('.tab').forEach((t,i)=>t.classList.toggle('on',i===n));document.querySelectorAll('.pnl').forEach((p,i)=>p.classList.toggle('on',i===n));if(n===2)loadStgUI()}

// 설정
function loadStgUI(){
  const s=getStg();
  document.getElementById('stgGasUrl').value=s.gasUrl||'';
  document.getElementById('stgThreshold').value=s.threshold||80;
  document.getElementById('stgDays').value=s.days||14;
  document.getElementById('gasCode').textContent=GAS_CODE;
}
function saveSettings(){
  const s={
    gasUrl:document.getElementById('stgGasUrl').value.trim(),
    threshold:parseInt(document.getElementById('stgThreshold').value)||80,
    days:parseInt(document.getElementById('stgDays').value)||14
  };
  localStorage.setItem(LS_KEY,JSON.stringify(s));
  document.getElementById('stgSaveStatus').textContent='✅ 저장됨 ('+new Date().toLocaleTimeString()+')';
  document.getElementById('stgSaveStatus').style.color='#22c55e';
  toast('✅ 설정 저장');
}
function copyGasCode(){
  navigator.clipboard.writeText(GAS_CODE).then(()=>toast('📋 GAS 코드 복사됨')).catch(()=>{
    const t=document.createElement('textarea');t.value=GAS_CODE;document.body.appendChild(t);t.select();document.execCommand('copy');document.body.removeChild(t);toast('📋 GAS 코드 복사됨');
  });
}
async function testGasConn(){
  const st=document.getElementById('stgConnStatus');
  const url=document.getElementById('stgGasUrl').value.trim();
  if(!url){st.textContent='❌ URL을 입력하세요';st.style.color='#ef4444';return}
  st.textContent='테스트 중...';st.style.color='var(--accent)';
  try{
    const r=await fetch(url+'?action=getData',{redirect:'follow'});
    if(!r.ok)throw new Error('HTTP '+r.status);
    const d=await r.json();
    if(d.success){st.textContent='✅ 연결 성공 ('+d.count+'건)';st.style.color='#22c55e'}
    else{st.textContent='⚠ 응답 오류: '+JSON.stringify(d);st.style.color='#f59e0b'}
  }catch(e){st.textContent='❌ 실패: '+e.message;st.style.color='#ef4444'}
}

// ========== 데이터 분석 ==========
let _rawData=[];
let _warnings=[];
let _allGroups=[];

async function fetchData(){
  const s=getStg();
  const url=s.gasUrl;
  if(!url)throw new Error('GAS URL 미설정 — ⚙ 설정 탭에서 입력하세요');
  const r=await fetch(url+'?action=getData',{redirect:'follow'});
  if(!r.ok)throw new Error('HTTP '+r.status);
  const d=await r.json();
  if(!d.success)throw new Error('API 오류');
  return d;
}

async function runAnalysis(){
  const btn=document.getElementById('btnAnalysis');
  const st=document.getElementById('analysisStatus');
  btn.disabled=true;st.style.display='block';st.textContent='📥 데이터 가져오는 중...';
  document.getElementById('warningList').innerHTML='<div class="loading"><span class="spin"></span>분석 중...</div>';
  document.getElementById('statsArea').style.display='none';
  document.getElementById('filterArea').style.display='none';
  document.getElementById('exportArea').style.display='none';

  try{
    const result=await fetchData();
    _rawData=result.data||[];
    st.textContent='📊 '+_rawData.length+'건 로드 → 분석 중...';
    await new Promise(r=>setTimeout(r,50));
    analyzeData();
    st.style.display='none';
    toast('✅ 분석 완료');
  }catch(e){
    st.textContent='❌ '+e.message;st.style.color='#ef4444';
    document.getElementById('warningList').innerHTML='<div style="text-align:center;padding:20px;color:var(--ng);font-size:12px">'+e.message+'</div>';
  }
  btn.disabled=false;
}

function parseDate(raw){
  if(!raw)return null;
  const s=String(raw).replace(/[^0-9]/g,'');
  if(s.length!==8)return null;
  const y=parseInt(s.substring(0,4)),m=parseInt(s.substring(4,6))-1,d=parseInt(s.substring(6,8));
  const dt=new Date(y,m,d);
  return isNaN(dt.getTime())?null:{dateObj:dt,dateStr:y+'-'+String(m+1).padStart(2,'0')+'-'+String(d+1).padStart(2,'0'),raw:s};
}

function analyzeData(){
  const stg=getStg();
  const threshold=(stg.threshold||80)/100;
  const days=stg.days||14;
  const now=new Date();
  const oneYearAgo=new Date(now.getFullYear()-1,now.getMonth(),now.getDate());
  const recentCutoff=new Date(now.getFullYear(),now.getMonth(),now.getDate()-days);

  // 컬럼 인덱스
  const C_DATE=0,C_PART=1,C_SPEC=15,C_G=6,C_ITEM=7,C_LOWER=20,C_UPPER=21,C_AVG=35;

  // 1. 파싱 & 그룹화
  const grouped={};
  let validCount=0;

  _rawData.forEach(row=>{
    const date=parseDate(row['c'+C_DATE]);
    if(!date||date.dateObj<oneYearAgo)return;
    const avg=parseFloat(row['c'+C_AVG]);
    if(isNaN(avg))return;
    validCount++;

    const partNo=String(row['c'+C_PART]||'');
    const spec=String(row['c'+C_SPEC]||'');
    const gVal=String(row['c'+C_G]||'');
    const item=String(row['c'+C_ITEM]||'');
    const lower=row['c'+C_LOWER];
    const upper=row['c'+C_UPPER];

    const key=partNo+'|'+gVal+'|'+item;
    if(!grouped[key]){
      grouped[key]={partNo,spec,gVal,item,lowerLimit:String(lower||'-'),upperLimit:String(upper||'-'),records:[]};
    }
    // 일자별 중복 방지 (같은 날짜+품번+항목은 첫 값만)
    const dateKey=date.raw;
    if(!grouped[key].records.find(r=>r.dateKey===dateKey)){
      grouped[key].records.push({date:date.dateStr,dateObj:date.dateObj,dateKey,average:avg});
    }
  });

  // 2. 정렬
  for(let k in grouped)grouped[k].records.sort((a,b)=>a.dateObj-b.dateObj);

  // 3. 위험 분석
  _warnings=[];
  _allGroups=Object.values(grouped);

  for(let group of _allGroups){
    if(!group.records.length)continue;
    const last=group.records[group.records.length-1];
    if(last.dateObj<recentCutoff)continue;

    const isZero=ZERO_APPROACH_ITEMS.includes(group.item);
    const lower=parseFloat(group.lowerLimit);
    const upper=parseFloat(group.upperLimit);
    const val=last.average;
    let warn=null;

    if(isZero){
      if(!isNaN(upper)){
        const th=upper*threshold;
        if(val>=th){
          warn={...group,type:'상한임박',itemType:'제로근접형',currentValue:val,thresholdVal:th,limitVal:upper,isUpper:true,date:last.date,pct:upper>0?(val/upper*100):100};
        }
      }
    }else{
      if(!isNaN(lower)&&!isNaN(upper)){
        const range=upper-lower;
        const upperTh=lower+range*threshold;
        const lowerTh=lower+range*(1-threshold);
        if(val>=upperTh){
          warn={...group,type:'상한임박',itemType:'중심공차형',currentValue:val,thresholdVal:upperTh,limitVal:upper,isUpper:true,date:last.date,pct:range>0?((val-lower)/range*100):100};
        }else if(val<=lowerTh){
          warn={...group,type:'하한임박',itemType:'중심공차형',currentValue:val,thresholdVal:lowerTh,limitVal:lower,isUpper:false,date:last.date,pct:range>0?((val-lower)/range*100):0};
        }
      }
    }
    if(warn)_warnings.push(warn);
  }

  // 정렬: 위험도 높은 순
  _warnings.sort((a,b)=>{
    const aPct=a.isUpper?a.pct:(100-a.pct);
    const bPct=b.isUpper?b.pct:(100-b.pct);
    return bPct-aPct;
  });

  // 통계 표시
  document.getElementById('statsArea').style.display='block';
  document.getElementById('statDanger').textContent=_warnings.length;
  document.getElementById('statTotal').textContent=_allGroups.length;
  document.getElementById('statData').textContent=validCount;

  // 필터 칩
  const parts=[...new Set(_warnings.map(w=>w.partNo))].sort();
  const filterDiv=document.getElementById('filterChips');
  filterDiv.innerHTML='<div class="filter-chip on" data-part="" onclick="toggleFilter(this)">전체</div>'+parts.map(p=>'<div class="filter-chip" data-part="'+p+'" onclick="toggleFilter(this)">'+p+'</div>').join('');
  document.getElementById('filterArea').style.display=_warnings.length?'block':'none';
  document.getElementById('exportArea').style.display=_warnings.length?'block':'none';

  renderWarnings('');
}

function toggleFilter(el){
  document.querySelectorAll('#filterChips .filter-chip').forEach(c=>c.classList.remove('on'));
  el.classList.add('on');
  renderWarnings(el.dataset.part);
}

function renderWarnings(partFilter){
  const c=document.getElementById('warningList');
  let list=partFilter?_warnings.filter(w=>w.partNo===partFilter):_warnings;

  if(!list.length){
    c.innerHTML=_warnings.length===0?
      '<div class="card" style="text-align:center;padding:24px"><div style="font-size:28px;margin-bottom:8px">✅</div><div style="font-size:14px;font-weight:700;color:var(--ok)">특이사항 없음</div><div style="font-size:11px;color:var(--text3);margin-top:4px">최근 측정 중 관리한계 80% 초과 항목이 없습니다</div></div>':
      '<div style="text-align:center;padding:16px;color:var(--text3);font-size:12px">필터 결과 없음</div>';
    return;
  }

  c.innerHTML=list.map((w,i)=>{
    const chartUrl=buildChartUrl(w);
    const limitType=w.isUpper?'상한':'하한';
    const icon=w.isUpper?'⬆️':'⬇️';
    const badgeColor=w.isUpper?'var(--ng)':'var(--warn)';
    const stg=getStg();
    const thPct=stg.threshold||80;

    return `<div class="warn-card ${w.isUpper?'danger':'warning'}" style="padding:0;overflow:hidden">
      <!-- 그래프 (상단) -->
      <div style="background:#fff;padding:4px">
        <img src="${chartUrl}" alt="관리도" style="width:100%;display:block;border-radius:8px 8px 0 0" onerror="this.style.display='none'">
      </div>
      <!-- 경고 제목 -->
      <div style="padding:12px 14px 8px;display:flex;align-items:center;gap:8px">
        <span style="font-size:16px">🚨</span>
        <span style="font-size:14px;font-weight:800;color:${badgeColor}">경고 ${i+1}/${list.length}</span>
        <span style="font-size:11px;padding:2px 8px;border-radius:10px;background:${w.isUpper?'var(--ng-bg)':'var(--warn-bg)'};color:${badgeColor};font-weight:700">${icon} ${w.type}(${thPct}%)</span>
      </div>
      <!-- 상세 정보 (텔레그램 형식) -->
      <div style="padding:4px 14px 10px;font-size:12px;line-height:2.0">
        <div>🔧 <span style="color:var(--text2)">부품번호:</span> <b>${w.partNo}</b></div>
        <div>📐 <span style="color:var(--text2)">규격:</span> <b>${w.spec||'-'}</b></div>
        <div>📋 <span style="color:var(--text2)">G열:</span> ${w.gVal}</div>
        <div>📏 <span style="color:var(--text2)">항목:</span> ${w.item} (${w.itemType})</div>
        <div>💥 <span style="color:var(--text2)">상태:</span> <b style="color:${badgeColor}">관리${limitType} ${thPct}% 위험구간</b></div>
        <div>📉 <span style="color:var(--text2)">측정값:</span> <b style="color:var(--ng);font-size:14px">${w.currentValue.toFixed(3)}</b></div>
        <div>🚧 <span style="color:var(--text2)">경고기준:</span> ${w.thresholdVal.toFixed(3)}</div>
        <div>${icon} <span style="color:var(--text2)">관리${limitType}:</span> ${w.limitVal}</div>
        <div>📅 <span style="color:var(--text2)">발생일자:</span> ${w.date}</div>
      </div>
      <!-- 작업표준 파일 -->
      <div id="fileArea_${i}" style="padding:0 14px 14px">
        <button class="btn-sm" onclick="searchFile(${i},'${w.partNo.replace(/'/g,"\\'")}')" style="width:100%;background:var(--surface2);color:var(--text2);border:1px solid var(--border);font-size:11px;padding:10px;display:flex;align-items:center;justify-content:center;gap:6px">
          <span>📋</span> 작업표준 열기
        </button>
      </div>
    </div>`;
  }).join('');

  // 분석 완료 후 자동으로 파일 검색
  list.forEach((w,i)=>searchFile(i,w.partNo));
}

// 작업표준 파일 검색
async function searchFile(idx,partNo){
  const area=document.getElementById('fileArea_'+idx);
  if(!area)return;
  const s=getStg();
  const url=s.gasUrl;
  if(!url)return; // GAS URL 없으면 버튼만 유지

  try{
    const r=await fetch(url+'?action=findFile&partNo='+encodeURIComponent(partNo),{redirect:'follow'});
    if(!r.ok)return;
    const d=await r.json();
    if(!d.success||!d.files||!d.files.length){
      area.innerHTML=`<div style="font-size:10px;color:var(--text3);text-align:center;padding:4px">📋 작업표준 파일 없음 (${partNo})</div>`;
      return;
    }
    area.innerHTML=d.files.map(f=>{
      const sizeKB=(f.size/1024).toFixed(1);
      const ext=f.name.split('.').pop().toLowerCase();
      const icon=ext==='xlsx'||ext==='xls'?'📊':ext==='pdf'?'📄':ext==='jpg'||ext==='png'?'🖼':'📋';
      return `<a href="${f.url}" target="_blank" style="display:flex;align-items:center;gap:10px;padding:10px 12px;background:var(--bg);border:1.5px solid var(--border);border-radius:8px;margin-bottom:4px;text-decoration:none;color:var(--text);transition:border-color .15s" onmouseover="this.style.borderColor='var(--accent)'" onmouseout="this.style.borderColor='var(--border)'">
        <span style="font-size:20px">${icon}</span>
        <span style="flex:1;min-width:0">
          <span style="display:block;font-size:12px;font-weight:700;color:var(--text);overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${f.name}</span>
          <span style="display:block;font-size:10px;color:var(--text3)">${sizeKB} KB</span>
        </span>
        <span style="font-size:10px;color:var(--accent);font-weight:600;flex-shrink:0">열기 →</span>
      </a>`;
    }).join('');
  }catch(e){
    // 실패 시 버튼 유지
  }
}

function buildChartUrl(w){
  const dates=w.records.map(r=>{const p=r.date.split('-');return (p[1]||'').replace(/^0/,'')+'/'+(p[2]||'').replace(/^0/,'')});
  const vals=w.records.map(r=>r.average);
  const lower=parseFloat(w.lowerLimit),upper=parseFloat(w.upperLimit);

  // Y축 범위 자동 계산 (데이터+한계 기반 여유)
  let allVals=[...vals];
  if(!isNaN(upper))allVals.push(upper);
  if(!isNaN(lower))allVals.push(lower);
  const yMin=Math.min(...allVals),yMax=Math.max(...allVals);
  const yPad=(yMax-yMin)*0.15||0.005;

  const datasets=[{
    label:'측정평균',data:vals,
    borderColor:'rgb(54,162,235)',backgroundColor:'rgba(54,162,235,0.08)',
    fill:true,tension:0.2,pointRadius:4,pointBackgroundColor:'rgb(54,162,235)',borderWidth:2
  }];
  if(!isNaN(upper))datasets.push({
    label:'관리상한 ('+upper+')',data:Array(vals.length).fill(upper),
    borderColor:'rgb(255,99,132)',borderDash:[6,4],borderWidth:1.5,fill:false,pointRadius:0
  });
  if(!isNaN(lower))datasets.push({
    label:'관리하한 ('+lower+')',data:Array(vals.length).fill(lower),
    borderColor:'rgb(255,159,64)',borderDash:[6,4],borderWidth:1.5,fill:false,pointRadius:0
  });

  const cfg={
    type:'line',
    data:{labels:dates,datasets:datasets},
    options:{
      plugins:{
        title:{display:true,text:w.partNo+' - '+w.item,font:{size:14,weight:'bold'}},
        legend:{position:'top',labels:{font:{size:10},boxWidth:12,padding:8}}
      },
      scales:{
        y:{min:yMin-yPad,max:yMax+yPad,ticks:{font:{size:10}},title:{display:false}},
        x:{ticks:{font:{size:9},maxRotation:45},title:{display:false}}
      },
      layout:{padding:{left:4,right:4,top:4,bottom:4}}
    }
  };
  return 'https://quickchart.io/chart?c='+encodeURIComponent(JSON.stringify(cfg))+'&w=600&h=350&bkg=white';
}

// 엑셀 내보내기
function exportWarnings(){
  if(!_warnings.length){toast('없음');return}
  const wb=XLSX.utils.book_new();
  const hd=['부품번호','규격','G열','항목','항목유형','상태','측정값','경고기준','하한','상한','위치%','발생일자'];
  const rows=_warnings.map(w=>[w.partNo,w.spec,w.gVal,w.item,w.itemType,w.type,w.currentValue,w.thresholdVal,w.lowerLimit,w.upperLimit,Math.round(w.pct)+'%',w.date]);
  const ws=XLSX.utils.aoa_to_sheet([hd,...rows]);
  ws['!cols']=hd.map(()=>({wch:14}));
  XLSX.utils.book_append_sheet(wb,ws,'위험항목');
  XLSX.writeFile(wb,'치수관리_위험_'+new Date().toISOString().split('T')[0].replace(/-/g,'')+'.xlsx');
  toast('📥 엑셀 다운로드');
}

// 전체 데이터 탭
async function loadAllData(){
  const st=document.getElementById('allDataStatus');
  st.textContent='로드 중...';
  try{
    const result=await fetchData();
    _rawData=result.data||[];
    st.textContent='✅ '+_rawData.length+'건 로드됨';
    renderAllData();
  }catch(e){st.textContent='❌ '+e.message}
}

function renderAllData(){
  const c=document.getElementById('allDataList');
  if(!_rawData.length){c.innerHTML='<div style="text-align:center;padding:16px;color:var(--text3);font-size:12px">데이터를 먼저 로드하세요</div>';return}
  const sp=(document.getElementById('searchPart').value||'').trim().toLowerCase();
  const si=(document.getElementById('searchItem').value||'').trim().toLowerCase();
  let filtered=_rawData.filter(r=>{
    if(sp&&!String(r.c1||'').toLowerCase().includes(sp))return false;
    if(si&&!String(r.c7||'').toLowerCase().includes(si))return false;
    return true;
  });
  const showing=filtered.slice(0,100);
  c.innerHTML=showing.map(r=>{
    const date=String(r.c0||'');const part=String(r.c1||'');const item=String(r.c7||'');const avg=r.c35;
    const lower=r.c20,upper=r.c21;
    return `<div style="display:flex;gap:6px;padding:6px 8px;background:var(--bg);border:1px solid rgba(255,255,255,.04);border-radius:6px;margin-bottom:3px;font-size:11px;align-items:center">
      <span style="color:var(--text3);min-width:65px">${date}</span>
      <span style="color:var(--accent);font-weight:600;min-width:80px">${part}</span>
      <span style="color:var(--text2);flex:1">${item}</span>
      <span style="font-weight:700;color:var(--text)">${avg!=null?Number(avg).toFixed(3):'-'}</span>
      <span style="color:var(--text3);font-size:9px">${lower||'-'}~${upper||'-'}</span>
    </div>`;
  }).join('');
  if(filtered.length>100)c.innerHTML+='<div style="text-align:center;padding:8px;color:var(--text3);font-size:11px">... 외 '+(filtered.length-100)+'건</div>';
}

// 초기화
window.addEventListener('DOMContentLoaded',()=>{loadStgUI()});
