<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=no">
<title>불량관리</title>
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
:root{--bg:#f0f2f5;--c:#fff;--pri:#1a237e;--pl:#e8eaf6;--b:#1565c0;--bl:#e3f2fd;--red:#c62828;--rl:#ffebee;--grn:#2e7d32;--gl:#e8f5e9;--amb:#e65100;--al:#fff3e0;--tx:#212121;--t2:#555;--t3:#999;--bd:#e0e0e0;--r:12px;--sh:0 1px 3px rgba(0,0,0,.08)}
*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent}
body{font-family:'Noto Sans KR',sans-serif;background:var(--bg);color:var(--tx);min-height:100vh;padding-bottom:16px}
.hd{background:linear-gradient(135deg,#1a237e,#283593);color:#fff;padding:14px 16px;position:sticky;top:0;z-index:100;display:flex;align-items:center;justify-content:space-between}
.hd h1{font-size:16px;font-weight:700}.hd .sub{font-size:10px;opacity:.7;margin-top:1px}
.hd-btn{background:rgba(255,255,255,.15);border:none;border-radius:8px;width:34px;height:34px;display:flex;align-items:center;justify-content:center;cursor:pointer;color:#fff;font-size:16px}
.tabs{display:flex;background:#fff;border-bottom:2px solid var(--bd);position:sticky;top:54px;z-index:90}
.tab{flex:1;padding:10px 4px;text-align:center;font-size:12px;font-weight:600;cursor:pointer;border-bottom:3px solid transparent;color:var(--t3)}
.tab.on{color:var(--pri);border-bottom-color:var(--pri)}
.tab .bdg{display:inline-flex;min-width:16px;height:16px;border-radius:8px;font-size:9px;font-weight:700;padding:0 4px;margin-left:2px;background:var(--red);color:#fff;align-items:center;justify-content:center}
.tab .bdg.z{background:var(--bd);color:var(--t3)}
.ct{padding:10px 12px;max-width:680px;margin:0 auto}
.pn{display:none}.pn.on{display:block}
.card{background:#fff;border-radius:var(--r);padding:14px;margin-bottom:10px;box-shadow:var(--sh)}
.card-tit{font-size:14px;font-weight:700;margin-bottom:10px;display:flex;align-items:center;gap:6px;justify-content:space-between}
.fg{margin-bottom:10px}
.fl{font-size:11px;font-weight:600;color:var(--t2);margin-bottom:3px}
input[type=text],input[type=number],input[type=date],select,textarea{width:100%;padding:9px 10px;border:1px solid var(--bd);border-radius:8px;font-size:13px;font-family:inherit;background:#fafafa}
input:focus,select:focus,textarea:focus{outline:none;border-color:var(--b);background:#fff}
.btn{padding:11px;border:none;border-radius:10px;font-size:13px;font-weight:700;cursor:pointer;font-family:inherit;width:100%}
.btn:active{transform:scale(.97)}
.btn-pri{background:linear-gradient(135deg,#1a237e,#283593);color:#fff}
.btn-grn{background:linear-gradient(135deg,#2e7d32,#43a047);color:#fff}
.btn-red{background:var(--rl);color:var(--red);border:1px solid #ffcdd2}
.btn-gray{background:#f5f5f5;color:#555;border:1px solid var(--bd)}
.btn-sm{padding:6px 12px;font-size:11px;width:auto;border-radius:7px}
.btn-row{display:flex;gap:6px}.btn-row .btn{flex:1}
.empty{text-align:center;padding:30px 16px;color:var(--t3);font-size:13px;line-height:1.6}

/* 기판 뷰어 */
.pcb-wrap{position:relative;background:#1a1a2e;border-radius:var(--r);overflow:hidden;touch-action:none;user-select:none;min-height:200px;margin-bottom:10px}
.pcb-wrap.empty-bg{display:flex;align-items:center;justify-content:center;border:2px dashed #555;min-height:250px;cursor:pointer}
.pcb-img{width:100%;display:block}
.zone{position:absolute;border:2px solid rgba(99,102,241,.7);background:rgba(99,102,241,.15);border-radius:4px;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:700;color:#fff;text-shadow:0 1px 2px rgba(0,0,0,.7);transition:background .15s;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;padding:0 3px;min-width:20px;min-height:20px}
.zone:active{background:rgba(99,102,241,.35)}
.zone.has-defect{border-color:rgba(239,68,68,.8);background:rgba(239,68,68,.2)}
.zone .z-count{position:absolute;top:-6px;right:-6px;background:var(--red);color:#fff;font-size:9px;font-weight:700;width:18px;height:18px;border-radius:50%;display:flex;align-items:center;justify-content:center;box-shadow:0 1px 3px rgba(0,0,0,.3)}
.zone.editing{border-color:#fdd835;background:rgba(253,216,53,.2);cursor:move}
.zone .z-resize{position:absolute;bottom:0;right:0;width:14px;height:14px;background:rgba(255,255,255,.6);cursor:nwse-resize;border-radius:2px 0 2px 0}

/* 모달 */
.ov{display:none;position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:200;align-items:flex-end;justify-content:center}
.ov.sh{display:flex}
.md{background:#fff;border-radius:16px 16px 0 0;width:100%;max-width:680px;max-height:85vh;overflow-y:auto;padding:18px;animation:su .25s}
@keyframes su{from{transform:translateY(100%)}to{transform:translateY(0)}}
.md h2{font-size:15px;font-weight:700;margin-bottom:14px}
.mb{display:flex;gap:6px;margin-top:14px}.mb .btn{flex:1}

/* 불량유형 선택 그리드 */
.dt-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:6px;margin-bottom:12px}
.dt-btn{padding:10px 6px;border:1.5px solid var(--bd);border-radius:8px;background:#fafafa;text-align:center;cursor:pointer;font-size:12px;font-weight:600;font-family:inherit;transition:.15s}
.dt-btn:active{transform:scale(.95)}
.dt-btn.sel{border-color:var(--red);background:var(--rl);color:var(--red)}
.dt-btn .dt-cat{font-size:9px;color:var(--t3);margin-top:1px}

/* 이력 */
.hi{padding:9px 0;border-bottom:1px solid #f0f0f0;font-size:12px}.hi:last-child{border-bottom:none}
.hi-top{display:flex;justify-content:space-between;align-items:center}
.hi-zone{font-weight:700;color:var(--pri)}.hi-time{font-size:10px;color:var(--t3)}
.hi-tags{display:flex;gap:4px;flex-wrap:wrap;margin-top:3px}
.hi-tag{font-size:10px;padding:1px 6px;border-radius:3px;font-weight:600;background:var(--rl);color:var(--red)}
.hi-acts{margin-top:4px}
.hi-acts button{padding:3px 8px;border:none;border-radius:4px;font-size:10px;font-weight:600;cursor:pointer;font-family:inherit;background:var(--rl);color:var(--red)}

/* 통계 */
.stats{display:grid;grid-template-columns:repeat(3,1fr);gap:6px;margin-bottom:10px}
.st{background:#fff;border-radius:var(--r);padding:12px 8px;text-align:center;box-shadow:var(--sh)}
.st .n{font-size:20px;font-weight:700}.st .l{font-size:10px;color:var(--t3);margin-top:1px}

/* 태그 아이템 */
.tag-item{display:flex;align-items:center;gap:6px;padding:6px 0;border-bottom:1px solid #f0f0f0;font-size:13px}
.tag-item:last-child{border-bottom:none}
.tag-item input{flex:1;padding:6px 8px;font-size:12px}
.tag-del{width:26px;height:26px;border:none;border-radius:6px;background:var(--rl);color:var(--red);font-size:12px;font-weight:700;cursor:pointer;flex-shrink:0;display:flex;align-items:center;justify-content:center}
.tag-cat{font-size:10px;color:var(--t3);padding:2px 6px;border-radius:3px;background:#f5f5f5;flex-shrink:0}
.add-row{display:flex;gap:6px;margin-top:8px}
.add-row input,.add-row select{flex:1;padding:6px 8px;font-size:12px}
.add-row button{padding:6px 12px;border:none;border-radius:6px;background:var(--bl);color:var(--b);font-size:11px;font-weight:700;cursor:pointer;font-family:inherit;flex-shrink:0}

.toast{position:fixed;bottom:20px;left:50%;transform:translateX(-50%) translateY(80px);background:#333;color:#fff;padding:9px 20px;border-radius:10px;font-size:12px;font-weight:500;z-index:9999;transition:transform .3s;white-space:nowrap}
.toast.sh{transform:translateX(-50%) translateY(0)}
</style>
</head>
<body>
<div class="hd">
  <div><h1>🔍 불량관리</h1><div class="sub" id="todayDisp"></div></div>
  <div style="display:flex;gap:6px">
    <button class="hd-btn" onclick="sw('set')">⚙</button>
  </div>
</div>
<div class="tabs">
  <div class="tab on" data-t="map" onclick="sw('map')">기판맵 <span class="bdg z" id="bdgDef">0</span></div>
  <div class="tab" data-t="hist" onclick="sw('hist')">이력</div>
  <div class="tab" data-t="dash" onclick="sw('dash')">통계</div>
  <div class="tab" data-t="set" onclick="sw('set')">설정</div>
</div>
<div class="ct">

<!-- 기판맵 탭 -->
<div class="pn on" id="pn-map">
  <div class="card" style="padding:10px">
    <div style="display:flex;gap:6px;margin-bottom:8px;align-items:center">
      <select id="modelSel" onchange="onModelChange()" style="flex:1;padding:8px;font-size:13px;border:1.5px solid var(--bd);border-radius:8px">
        <option value="">-- 기종 선택 --</option>
      </select>
      <select id="sideSel" onchange="renderPcb()" style="width:80px;padding:8px;font-size:13px;border:1.5px solid var(--bd);border-radius:8px">
        <option value="top">TOP</option>
        <option value="bottom">BOTTOM</option>
      </select>
      <button class="btn-sm btn-gray" onclick="toggleEditMode()" id="btnEdit">✏ 편집</button>
    </div>
  </div>

  <!-- 기판 뷰어 -->
  <div class="pcb-wrap empty-bg" id="pcbWrap" onclick="onPcbClick(event)">
    <img class="pcb-img" id="pcbImg" style="display:none">
    <div id="pcbEmpty" style="color:#888;font-size:13px;text-align:center;padding:20px">
      설정 탭에서 기종을 등록하고<br>기판 이미지를 업로드하세요
    </div>
  </div>

  <!-- 편집모드 안내 -->
  <div class="card" id="editGuide" style="display:none;border:2px solid #fdd835;background:#fffde7">
    <div style="font-size:12px;color:#5d4037;line-height:1.6">
      <b>📐 편집 모드</b><br>
      • 기판 위를 <b>터치/클릭</b>하여 영역 추가<br>
      • 영역을 <b>드래그</b>하여 이동<br>
      • 우측 하단 모서리를 드래그하여 <b>크기 조절</b><br>
      • 영역 이름을 클릭하여 <b>이름 변경/삭제</b>
    </div>
    <div style="margin-top:8px;display:flex;gap:6px">
      <button class="btn btn-pri" onclick="toggleEditMode()" style="font-size:12px;padding:8px">✅ 편집 완료</button>
    </div>
  </div>

  <!-- 현재 불량 요약 -->
  <div class="card" id="defectSummary" style="display:none">
    <div class="card-tit"><span>📊 현재 불량 현황</span><button class="btn-sm btn-red" onclick="clearCurrentDefects()">초기화</button></div>
    <div id="defSumBody"></div>
  </div>
</div>

<!-- 이력 탭 -->
<div class="pn" id="pn-hist">
  <div class="card">
    <div class="card-tit"><span>📋 불량 이력</span><button class="btn-sm btn-red" onclick="clearHist()">전체삭제</button></div>
    <div style="display:flex;gap:6px;margin-bottom:8px">
      <input type="date" id="histDate" onchange="renderHist()" style="flex:1;padding:6px;font-size:12px">
      <select id="histModel" onchange="renderHist()" style="flex:1;padding:6px;font-size:12px"><option value="">전체기종</option></select>
    </div>
    <div id="histList"></div>
    <div class="empty" id="histEmpty" style="display:none">이력이 없습니다.</div>
  </div>
</div>

<!-- 통계 탭 -->
<div class="pn" id="pn-dash">
  <div class="stats" id="dashStats"></div>
  <div class="card" id="dashByZone"><div class="card-tit"><span>영역별 불량</span></div><div id="dashZoneBody"></div></div>
  <div class="card" id="dashByType"><div class="card-tit"><span>유형별 불량</span></div><div id="dashTypeBody"></div></div>
</div>

<!-- 설정 탭 -->
<div class="pn" id="pn-set">
  <!-- 기종 관리 -->
  <div class="card">
    <div class="card-tit"><span>📱 기종 관리</span></div>
    <div id="modelList"></div>
    <div class="add-row">
      <input type="text" id="newModelName" placeholder="새 기종명">
      <button onclick="addModel()">추가</button>
    </div>
  </div>

  <!-- 기판 이미지 업로드 -->
  <div class="card" id="imgUploadCard">
    <div class="card-tit"><span>🖼 기판 이미지</span></div>
    <div id="imgUploadBody" style="font-size:12px;color:var(--t3)">기종을 먼저 선택하세요.</div>
  </div>

  <!-- 불량유형 관리 -->
  <div class="card">
    <div class="card-tit"><span>⚠ 불량유형 관리</span><button class="btn-sm btn-gray" onclick="resetDefTypes()">기본값</button></div>
    <div id="defTypeList"></div>
    <div class="add-row">
      <input type="text" id="newDtName" placeholder="새 불량유형">
      <select id="newDtCat"><option value="SMT">SMT</option><option value="외관">외관</option><option value="기타">기타</option></select>
      <button onclick="addDefType()">추가</button>
    </div>
  </div>

  <!-- 데이터 관리 -->
  <div class="card">
    <div class="card-tit"><span>📂 데이터 관리</span></div>
    <div class="btn-row" style="margin-bottom:6px">
      <button class="btn btn-gray" onclick="exportAll()">📤 내보내기</button>
      <button class="btn btn-gray" onclick="document.getElementById('impFile').click()">📥 가져오기</button>
    </div>
    <input type="file" id="impFile" accept=".json" style="display:none" onchange="importAll(this)">
    <button class="btn btn-red" onclick="resetAll()">🗑 전체 초기화</button>
  </div>
</div>
</div>

<!-- 불량 입력 모달 -->
<div class="ov" id="defModal">
  <div class="md">
    <h2 id="defModalTitle">⚠ 불량 입력</h2>
    <div style="font-size:12px;color:var(--b);font-weight:600;margin-bottom:10px" id="defZoneName"></div>
    <div class="fl">불량유형 선택</div>
    <div class="dt-grid" id="dtGrid"></div>
    <div class="fg">
      <div class="fl">수량</div>
      <input type="number" id="defQty" value="1" min="1" inputmode="numeric" style="font-size:16px;padding:12px;text-align:center;font-weight:700">
    </div>
    <div class="fg">
      <div class="fl">비고</div>
      <input type="text" id="defMemo" placeholder="참고사항 (선택)">
    </div>
    <input type="hidden" id="defZoneId" value="">
    <div class="mb">
      <button class="btn btn-gray" onclick="closeModal('defModal')">취소</button>
      <button class="btn btn-pri" onclick="saveDefect()" style="background:linear-gradient(135deg,var(--red),#e53935)">⚠ 불량 등록</button>
    </div>
  </div>
</div>

<!-- 영역 편집 모달 -->
<div class="ov" id="zoneModal">
  <div class="md">
    <h2>📐 영역 편집</h2>
    <div class="fg"><div class="fl">영역 이름</div><input type="text" id="zoneEditName"></div>
    <input type="hidden" id="zoneEditId" value="">
    <div class="mb">
      <button class="btn btn-red" onclick="deleteZone()" style="flex:0;padding:11px 16px">🗑</button>
      <button class="btn btn-gray" onclick="closeModal('zoneModal')">취소</button>
      <button class="btn btn-pri" onclick="saveZoneName()">저장</button>
    </div>
  </div>
</div>

<input type="file" id="pcbFileInput" accept="image/*" style="display:none">
<div class="toast" id="tst"></div>

<script>
// ============================================================
//  저장소
// ============================================================
const LS={models:'DEF_MODELS',defTypes:'DEF_TYPES',hist:'DEF_HIST',current:'DEF_CUR'};
const load=k=>{try{return JSON.parse(localStorage.getItem(k))||null}catch{return null}};
const save=(k,v)=>localStorage.setItem(k,JSON.stringify(v));

const DEFAULT_TYPES=[
  {id:'t1',name:'미납',cat:'SMT'},{id:'t2',name:'쇼트',cat:'SMT'},{id:'t3',name:'틀어짐',cat:'SMT'},
  {id:'t4',name:'들뜸',cat:'SMT'},{id:'t5',name:'브릿지',cat:'SMT'},{id:'t6',name:'미삽',cat:'SMT'},
  {id:'t7',name:'냉납',cat:'SMT'},{id:'t8',name:'과납',cat:'SMT'},{id:'t9',name:'역삽',cat:'SMT'},
  {id:'t10',name:'스크래치',cat:'외관'},{id:'t11',name:'오염',cat:'외관'},{id:'t12',name:'변색',cat:'외관'},
  {id:'t13',name:'크랙',cat:'외관'},{id:'t14',name:'찍힘',cat:'외관'},{id:'t15',name:'이물',cat:'외관'}
];

// models: [{id,name,images:{top:'dataurl',bottom:'dataurl'},zones:[{id,name,x%,y%,w%,h%,side}]}]
let models=load(LS.models)||[];
let defTypes=load(LS.defTypes)||JSON.parse(JSON.stringify(DEFAULT_TYPES));
let hist=load(LS.hist)||[];
let currentDefects=load(LS.current)||{}; // {zoneId:[{typeId,typeName,qty,memo,ts}]}

let curModel=null;
let editMode=false;
let dragZone=null,dragStart=null,resizing=false;

// 날짜
function fmtD(d){return d.getFullYear()+'-'+String(d.getMonth()+1).padStart(2,'0')+'-'+String(d.getDate()).padStart(2,'0')}
function fmtT(d){return String(d.getHours()).padStart(2,'0')+':'+String(d.getMinutes()).padStart(2,'0')}
const now=new Date();const iso=fmtD(now);
document.getElementById('todayDisp').textContent=iso;
function uid(){return Date.now().toString(36)+Math.random().toString(36).slice(2,6)}

// ============================================================
//  초기 렌더
// ============================================================
function init(){
  populateModelSel();renderDefTypes();renderModels();renderPcb();
}

function populateModelSel(){
  const sel=document.getElementById('modelSel');
  const hm=document.getElementById('histModel');
  const cur=sel.value;
  sel.innerHTML='<option value="">-- 기종 선택 --</option>';
  hm.innerHTML='<option value="">전체기종</option>';
  models.forEach(m=>{
    sel.innerHTML+='<option value="'+m.id+'">'+m.name+'</option>';
    hm.innerHTML+='<option value="'+m.id+'">'+m.name+'</option>';
  });
  if(cur)sel.value=cur;
}

function onModelChange(){
  const id=document.getElementById('modelSel').value;
  curModel=models.find(m=>m.id===id)||null;
  editMode=false;
  document.getElementById('btnEdit').textContent='✏ 편집';
  document.getElementById('editGuide').style.display='none';
  renderPcb();renderImgUpload();
}

// ============================================================
//  기판 렌더링
// ============================================================
function renderPcb(){
  const wrap=document.getElementById('pcbWrap');
  const img=document.getElementById('pcbImg');
  const emp=document.getElementById('pcbEmpty');
  const side=document.getElementById('sideSel').value;

  // 기존 영역 제거
  wrap.querySelectorAll('.zone').forEach(z=>z.remove());

  if(!curModel){
    wrap.classList.add('empty-bg');img.style.display='none';emp.style.display='';
    emp.innerHTML='설정 탭에서 기종을 등록하고<br>기판 이미지를 업로드하세요';
    renderDefSummary();return;
  }

  const imgSrc=curModel.images&&curModel.images[side];
  if(!imgSrc){
    wrap.classList.add('empty-bg');img.style.display='none';emp.style.display='';
    emp.innerHTML='설정 탭에서 '+side.toUpperCase()+' 이미지를 업로드하세요';
    renderDefSummary();return;
  }

  wrap.classList.remove('empty-bg');
  img.src=imgSrc;img.style.display='block';emp.style.display='none';

  // 이미지 로드 후 영역 그리기
  img.onload=()=>{drawZones()};
  if(img.complete)drawZones();
  renderDefSummary();
}

function drawZones(){
  const wrap=document.getElementById('pcbWrap');
  const side=document.getElementById('sideSel').value;
  wrap.querySelectorAll('.zone').forEach(z=>z.remove());
  if(!curModel)return;

  const zones=(curModel.zones||[]).filter(z=>z.side===side);
  zones.forEach(z=>{
    const el=document.createElement('div');
    el.className='zone'+(editMode?' editing':'');
    el.dataset.id=z.id;
    el.style.left=z.x+'%';el.style.top=z.y+'%';el.style.width=z.w+'%';el.style.height=z.h+'%';
    el.textContent=z.name;

    // 불량 카운트 배지
    const defs=currentDefects[z.id];
    if(defs&&defs.length){
      const total=defs.reduce((s,d)=>s+d.qty,0);
      el.classList.add('has-defect');
      const badge=document.createElement('span');badge.className='z-count';badge.textContent=total;
      el.appendChild(badge);
    }

    if(editMode){
      const rh=document.createElement('div');rh.className='z-resize';el.appendChild(rh);
      el.addEventListener('pointerdown',e=>startZoneDrag(e,z.id));
      el.addEventListener('click',e=>{if(!dragMoved)openZoneEdit(z.id);e.stopPropagation()});
    }else{
      el.addEventListener('click',e=>{e.stopPropagation();openDefectModal(z.id)});
    }
    wrap.appendChild(el);
  });
}

// ============================================================
//  편집 모드 (영역 추가/이동/크기조절)
// ============================================================
let dragMoved=false;

function toggleEditMode(){
  if(!curModel){toast('기종을 먼저 선택하세요',1);return}
  editMode=!editMode;
  document.getElementById('btnEdit').textContent=editMode?'✅ 완료':'✏ 편집';
  document.getElementById('editGuide').style.display=editMode?'':'none';
  renderPcb();
}

function onPcbClick(e){
  if(!editMode||!curModel)return;
  if(e.target.closest('.zone'))return;
  const wrap=document.getElementById('pcbWrap');
  const rect=wrap.getBoundingClientRect();
  const x=((e.clientX-rect.left)/rect.width*100).toFixed(1);
  const y=((e.clientY-rect.top)/rect.height*100).toFixed(1);
  const side=document.getElementById('sideSel').value;
  const num=(curModel.zones||[]).filter(z=>z.side===side).length+1;
  if(!curModel.zones)curModel.zones=[];
  curModel.zones.push({id:uid(),name:'영역'+num,x:parseFloat(x),y:parseFloat(y),w:15,h:12,side});
  save(LS.models,models);renderPcb();toast('영역 추가됨');
}

function startZoneDrag(e,zid){
  e.preventDefault();
  const el=e.target.closest('.zone');if(!el)return;
  const isResize=e.target.classList.contains('z-resize');
  const wrap=document.getElementById('pcbWrap');
  const rect=wrap.getBoundingClientRect();
  const zone=curModel.zones.find(z=>z.id===zid);if(!zone)return;
  dragMoved=false;

  const startX=e.clientX,startY=e.clientY;
  const origX=zone.x,origY=zone.y,origW=zone.w,origH=zone.h;

  function onMove(ev){
    ev.preventDefault();
    const dx=(ev.clientX-startX)/rect.width*100;
    const dy=(ev.clientY-startY)/rect.height*100;
    if(Math.abs(dx)>0.5||Math.abs(dy)>0.5)dragMoved=true;
    if(isResize){
      zone.w=Math.max(5,origW+dx);zone.h=Math.max(5,origH+dy);
    }else{
      zone.x=Math.max(0,Math.min(100-zone.w,origX+dx));
      zone.y=Math.max(0,Math.min(100-zone.h,origY+dy));
    }
    el.style.left=zone.x+'%';el.style.top=zone.y+'%';
    el.style.width=zone.w+'%';el.style.height=zone.h+'%';
  }
  function onUp(){
    document.removeEventListener('pointermove',onMove);
    document.removeEventListener('pointerup',onUp);
    save(LS.models,models);
  }
  document.addEventListener('pointermove',onMove);
  document.addEventListener('pointerup',onUp);
}

function openZoneEdit(zid){
  const zone=curModel.zones.find(z=>z.id===zid);if(!zone)return;
  document.getElementById('zoneEditName').value=zone.name;
  document.getElementById('zoneEditId').value=zid;
  openModal('zoneModal');
}
function saveZoneName(){
  const zid=document.getElementById('zoneEditId').value;
  const name=document.getElementById('zoneEditName').value.trim();
  if(!name){toast('이름을 입력하세요',1);return}
  const zone=curModel.zones.find(z=>z.id===zid);if(zone)zone.name=name;
  save(LS.models,models);closeModal('zoneModal');renderPcb();toast('변경됨');
}
function deleteZone(){
  const zid=document.getElementById('zoneEditId').value;
  if(!confirm('이 영역을 삭제할까요?'))return;
  curModel.zones=curModel.zones.filter(z=>z.id!==zid);
  delete currentDefects[zid];save(LS.current,currentDefects);
  save(LS.models,models);closeModal('zoneModal');renderPcb();toast('삭제됨');
}

// ============================================================
//  불량 입력
// ============================================================
let selType=null;

function openDefectModal(zid){
  const zone=curModel.zones.find(z=>z.id===zid);if(!zone)return;
  document.getElementById('defModalTitle').textContent='⚠ '+zone.name+' 불량 입력';
  document.getElementById('defZoneName').textContent='📍 '+zone.name;
  document.getElementById('defZoneId').value=zid;
  document.getElementById('defQty').value=1;
  document.getElementById('defMemo').value='';
  selType=null;

  // 불량유형 그리드
  const grid=document.getElementById('dtGrid');
  const byCat={};defTypes.forEach(t=>{if(!byCat[t.cat])byCat[t.cat]=[];byCat[t.cat].push(t)});
  let h='';
  Object.entries(byCat).forEach(([cat,types])=>{
    types.forEach(t=>{
      h+='<div class="dt-btn" data-tid="'+t.id+'" onclick="selectDefType(this,\''+t.id+'\')">'+t.name+'<div class="dt-cat">'+cat+'</div></div>';
    });
  });
  grid.innerHTML=h;
  openModal('defModal');
}

function selectDefType(el,tid){
  document.querySelectorAll('#dtGrid .dt-btn').forEach(b=>b.classList.remove('sel'));
  el.classList.add('sel');selType=tid;
}

function saveDefect(){
  if(!selType){toast('불량유형을 선택하세요',1);return}
  const zid=document.getElementById('defZoneId').value;
  const qty=parseInt(document.getElementById('defQty').value)||1;
  const memo=document.getElementById('defMemo').value.trim();
  const dt=defTypes.find(t=>t.id===selType);if(!dt)return;

  if(!currentDefects[zid])currentDefects[zid]=[];
  currentDefects[zid].push({typeId:dt.id,typeName:dt.name,cat:dt.cat,qty,memo,ts:fmtD(new Date())+' '+fmtT(new Date())});
  save(LS.current,currentDefects);

  // 이력에도 추가
  const zone=curModel.zones.find(z=>z.id===zid);
  hist.unshift({
    id:uid(),date:iso,time:fmtT(new Date()),
    model:curModel.name,modelId:curModel.id,
    zone:zone?zone.name:'',zoneId:zid,
    side:document.getElementById('sideSel').value,
    type:dt.name,typeCat:dt.cat,qty,memo
  });
  if(hist.length>1000)hist.length=1000;
  save(LS.hist,hist);

  closeModal('defModal');renderPcb();updBadge();
  if(navigator.vibrate)navigator.vibrate([50,30,50]);
  toast('⚠ '+dt.name+' '+qty+'건 등록');
}

function renderDefSummary(){
  const card=document.getElementById('defectSummary');
  const body=document.getElementById('defSumBody');
  const entries=Object.entries(currentDefects).filter(([,v])=>v.length>0);
  if(!entries.length){card.style.display='none';return}
  card.style.display='';
  let total=0;
  let h='<table style="width:100%;font-size:12px;border-collapse:collapse">';
  h+='<tr style="border-bottom:2px solid var(--bd)"><th style="text-align:left;padding:4px">영역</th><th style="text-align:left;padding:4px">유형</th><th style="text-align:center;padding:4px">수량</th></tr>';
  entries.forEach(([zid,defs])=>{
    const zone=curModel?curModel.zones.find(z=>z.id===zid):null;
    const zname=zone?zone.name:zid;
    defs.forEach((d,i)=>{
      total+=d.qty;
      h+='<tr style="border-bottom:1px solid #f0f0f0"><td style="padding:4px;color:var(--b);font-weight:600">'+(i===0?zname:'')+'</td><td style="padding:4px"><span style="color:var(--red);font-weight:600">'+d.typeName+'</span></td><td style="text-align:center;padding:4px;font-weight:700">'+d.qty+'</td></tr>';
    });
  });
  h+='<tr style="border-top:2px solid var(--bd);font-weight:700"><td style="padding:6px" colspan="2">합계</td><td style="text-align:center;padding:6px;color:var(--red);font-size:16px">'+total+'</td></tr>';
  h+='</table>';
  body.innerHTML=h;
}

function clearCurrentDefects(){
  if(!confirm('현재 불량 기록을 초기화할까요?'))return;
  currentDefects={};save(LS.current,currentDefects);renderPcb();updBadge();toast('초기화됨');
}

function updBadge(){
  const total=Object.values(currentDefects).reduce((s,arr)=>s+arr.reduce((ss,d)=>ss+d.qty,0),0);
  const el=document.getElementById('bdgDef');el.textContent=total;el.className='bdg'+(total?'':' z');
}

// ============================================================
//  이력
// ============================================================
function renderHist(){
  const c=document.getElementById('histList'),emp=document.getElementById('histEmpty');
  const fd=document.getElementById('histDate').value;
  const fm=document.getElementById('histModel').value;
  let list=hist;
  if(fd)list=list.filter(h=>h.date===fd);
  if(fm)list=list.filter(h=>h.modelId===fm);
  if(!list.length){c.innerHTML='';emp.style.display='';return}
  emp.style.display='none';
  c.innerHTML=list.slice(0,100).map(h=>'<div class="hi"><div class="hi-top"><span class="hi-zone">'+h.model+' / '+h.zone+'</span><span class="hi-time">'+h.date+' '+h.time+'</span></div><div class="hi-tags"><span class="hi-tag">'+h.type+'</span><span class="hi-tag" style="background:var(--bl);color:var(--b)">×'+h.qty+'</span><span class="hi-tag" style="background:#f5f5f5;color:var(--t3)">'+h.side.toUpperCase()+'</span></div>'+(h.memo?'<div style="font-size:10px;color:var(--t3);margin-top:2px">'+h.memo+'</div>':'')+'<div class="hi-acts"><button onclick="delHistItem(\''+h.id+'\')">🗑삭제</button></div></div>').join('');
}
function delHistItem(id){if(!confirm('삭제?'))return;hist=hist.filter(h=>h.id!==id);save(LS.hist,hist);renderHist();toast('삭제됨')}
function clearHist(){if(!hist.length)return;if(!confirm('전체 삭제?'))return;hist=[];save(LS.hist,[]);renderHist();toast('삭제됨')}

// ============================================================
//  통계
// ============================================================
function renderDash(){
  const fd=hist.filter(h=>h.date===iso);
  const total=fd.reduce((s,h)=>s+h.qty,0);
  const types=[...new Set(fd.map(h=>h.type))].length;
  const zones=[...new Set(fd.map(h=>h.zone))].length;
  document.getElementById('dashStats').innerHTML='<div class="st"><div class="n" style="color:var(--red)">'+total+'</div><div class="l">오늘 불량</div></div><div class="st"><div class="n" style="color:var(--amb)">'+types+'</div><div class="l">유형수</div></div><div class="st"><div class="n" style="color:var(--b)">'+zones+'</div><div class="l">영역수</div></div>';

  // 영역별
  const byZone={};fd.forEach(h=>{if(!byZone[h.zone])byZone[h.zone]=0;byZone[h.zone]+=h.qty});
  const zb=document.getElementById('dashZoneBody');
  if(!Object.keys(byZone).length){zb.innerHTML='<div class="empty" style="padding:10px">데이터 없음</div>'}
  else{const mx=Math.max(...Object.values(byZone));zb.innerHTML=Object.entries(byZone).sort((a,b)=>b[1]-a[1]).map(([z,v])=>'<div style="display:flex;align-items:center;gap:8px;margin-bottom:4px;font-size:12px"><span style="width:60px;text-align:right;font-weight:600;color:var(--b);overflow:hidden;text-overflow:ellipsis;white-space:nowrap">'+z+'</span><div style="flex:1;height:16px;background:#f5f5f5;border-radius:3px;overflow:hidden"><div style="height:100%;width:'+(v/mx*100)+'%;background:var(--red);border-radius:3px"></div></div><span style="width:30px;text-align:right;font-weight:700;color:var(--red)">'+v+'</span></div>').join('')}

  // 유형별
  const byType={};fd.forEach(h=>{if(!byType[h.type])byType[h.type]=0;byType[h.type]+=h.qty});
  const tb=document.getElementById('dashTypeBody');
  if(!Object.keys(byType).length){tb.innerHTML='<div class="empty" style="padding:10px">데이터 없음</div>'}
  else{const mx2=Math.max(...Object.values(byType));tb.innerHTML=Object.entries(byType).sort((a,b)=>b[1]-a[1]).map(([t,v])=>'<div style="display:flex;align-items:center;gap:8px;margin-bottom:4px;font-size:12px"><span style="width:60px;text-align:right;font-weight:600;color:var(--amb);overflow:hidden;text-overflow:ellipsis;white-space:nowrap">'+t+'</span><div style="flex:1;height:16px;background:#f5f5f5;border-radius:3px;overflow:hidden"><div style="height:100%;width:'+(v/mx2*100)+'%;background:var(--amb);border-radius:3px"></div></div><span style="width:30px;text-align:right;font-weight:700;color:var(--amb)">'+v+'</span></div>').join('')}
}

// ============================================================
//  설정: 기종 관리
// ============================================================
function renderModels(){
  const c=document.getElementById('modelList');
  if(!models.length){c.innerHTML='<div style="padding:8px;color:var(--t3);font-size:12px;text-align:center">등록된 기종 없음</div>';return}
  c.innerHTML=models.map(m=>'<div class="tag-item"><span style="flex:1;font-weight:600">'+m.name+'</span><span class="tag-cat">'+(m.zones||[]).length+'영역</span><button class="tag-del" onclick="delModel(\''+m.id+'\')">✕</button></div>').join('');
}
function addModel(){
  const name=document.getElementById('newModelName').value.trim();
  if(!name){toast('기종명을 입력하세요',1);return}
  if(models.some(m=>m.name===name)){toast('이미 존재',1);return}
  models.push({id:uid(),name,images:{},zones:[]});
  save(LS.models,models);document.getElementById('newModelName').value='';
  populateModelSel();renderModels();toast('추가됨');
}
function delModel(id){
  if(!confirm('삭제?'))return;
  models=models.filter(m=>m.id!==id);save(LS.models,models);
  if(curModel&&curModel.id===id){curModel=null;document.getElementById('modelSel').value=''}
  populateModelSel();renderModels();renderPcb();toast('삭제됨');
}

// 이미지 업로드
function renderImgUpload(){
  const body=document.getElementById('imgUploadBody');
  if(!curModel){body.innerHTML='<div style="color:var(--t3);font-size:12px">기종을 먼저 선택하세요.</div>';return}
  body.innerHTML='<div style="display:flex;gap:6px;margin-bottom:6px"><button class="btn btn-gray" onclick="uploadImg(\'top\')" style="flex:1;font-size:12px;padding:8px">📷 TOP 이미지</button><button class="btn btn-gray" onclick="uploadImg(\'bottom\')" style="flex:1;font-size:12px;padding:8px">📷 BOTTOM 이미지</button></div>'
    +(curModel.images&&curModel.images.top?'<div style="font-size:10px;color:var(--grn);margin-bottom:2px">✅ TOP 등록됨</div>':'<div style="font-size:10px;color:var(--t3);margin-bottom:2px">TOP 미등록</div>')
    +(curModel.images&&curModel.images.bottom?'<div style="font-size:10px;color:var(--grn)">✅ BOTTOM 등록됨</div>':'<div style="font-size:10px;color:var(--t3)">BOTTOM 미등록</div>');
}

let uploadSide='';
function uploadImg(side){
  if(!curModel){toast('기종을 먼저 선택하세요',1);return}
  uploadSide=side;document.getElementById('pcbFileInput').click();
}
document.getElementById('pcbFileInput').addEventListener('change',function(e){
  const file=e.target.files[0];if(!file||!curModel)return;
  const reader=new FileReader();
  reader.onload=function(ev){
    if(!curModel.images)curModel.images={};
    curModel.images[uploadSide]=ev.target.result;
    save(LS.models,models);renderPcb();renderImgUpload();toast(uploadSide.toUpperCase()+' 이미지 등록됨');
  };
  reader.readAsDataURL(file);e.target.value='';
});

// ============================================================
//  설정: 불량유형 관리
// ============================================================
function renderDefTypes(){
  const c=document.getElementById('defTypeList');
  const byCat={};defTypes.forEach(t=>{if(!byCat[t.cat])byCat[t.cat]=[];byCat[t.cat].push(t)});
  let h='';
  Object.entries(byCat).forEach(([cat,types])=>{
    h+='<div style="font-size:10px;font-weight:700;color:var(--t3);padding:6px 0 2px;border-bottom:1px solid var(--bd)">'+cat+'</div>';
    types.forEach(t=>{
      h+='<div class="tag-item"><span style="flex:1">'+t.name+'</span><span class="tag-cat">'+t.cat+'</span><button class="tag-del" onclick="delDefType(\''+t.id+'\')">✕</button></div>';
    });
  });
  c.innerHTML=h;
}
function addDefType(){
  const name=document.getElementById('newDtName').value.trim();
  const cat=document.getElementById('newDtCat').value;
  if(!name){toast('유형명을 입력하세요',1);return}
  if(defTypes.some(t=>t.name===name)){toast('이미 존재',1);return}
  defTypes.push({id:uid(),name,cat});
  save(LS.defTypes,defTypes);document.getElementById('newDtName').value='';
  renderDefTypes();toast('추가됨');
}
function delDefType(id){
  defTypes=defTypes.filter(t=>t.id!==id);save(LS.defTypes,defTypes);renderDefTypes();toast('삭제됨');
}
function resetDefTypes(){
  if(!confirm('기본 불량유형으로 복원?'))return;
  defTypes=JSON.parse(JSON.stringify(DEFAULT_TYPES));
  save(LS.defTypes,defTypes);renderDefTypes();toast('기본값 복원');
}

// ============================================================
//  데이터 관리
// ============================================================
function exportAll(){
  const data={models,defTypes,hist};
  // images는 base64라 용량이 클 수 있으므로 경고
  const blob=new Blob([JSON.stringify(data)],{type:'application/json'});
  const a=document.createElement('a');a.href=URL.createObjectURL(blob);
  a.download='불량관리_'+iso+'.json';a.click();toast('내보내기 완료');
}
function importAll(inp){
  const f=inp.files[0];if(!f)return;
  const r=new FileReader();r.onload=function(e){
    try{
      const d=JSON.parse(e.target.result);
      if(d.models)models=d.models;
      if(d.defTypes)defTypes=d.defTypes;
      if(d.hist)hist=d.hist;
      save(LS.models,models);save(LS.defTypes,defTypes);save(LS.hist,hist);
      curModel=null;document.getElementById('modelSel').value='';
      init();toast('가져오기 완료');
    }catch{toast('파일 오류',1)}
  };r.readAsText(f);inp.value='';
}
function resetAll(){
  if(!confirm('모든 데이터 삭제?'))return;if(!confirm('정말?'))return;
  models=[];defTypes=JSON.parse(JSON.stringify(DEFAULT_TYPES));hist=[];currentDefects={};
  save(LS.models,[]);save(LS.defTypes,defTypes);save(LS.hist,[]);save(LS.current,{});
  curModel=null;document.getElementById('modelSel').value='';
  init();toast('초기화 완료');
}

// ============================================================
//  유틸
// ============================================================
function sw(t){
  document.querySelectorAll('.tab').forEach(el=>el.classList.toggle('on',el.dataset.t===t));
  document.querySelectorAll('.pn').forEach(el=>el.classList.toggle('on',el.id==='pn-'+t));
  if(t==='hist')renderHist();
  if(t==='dash')renderDash();
  if(t==='set'){renderModels();renderDefTypes();renderImgUpload()}
  if(t==='map')renderPcb();
}
function openModal(id){document.getElementById(id).classList.add('sh')}
function closeModal(id){document.getElementById(id).classList.remove('sh')}
function toast(m,e){const t=document.getElementById('tst');t.textContent=m;t.style.background=e?'var(--red)':'#333';t.classList.add('sh');setTimeout(()=>t.classList.remove('sh'),3000)}

init();updBadge();
</script>
